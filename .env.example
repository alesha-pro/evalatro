# Copy to .env (gitignored). API keys stay local.
BASE_URL=https://openrouter.ai/api/v1
BASE_KEY=
MODEL=
MODEL_MODE=tools

# Optional model knobs:
# MODEL_MAX_TOKENS=16000
# MODEL_TEMPERATURE=0.3
# MODEL_NAME=my-label

# Named presets in balatro.config.json read their own keys from env vars, e.g.:
# OPENROUTER_API_KEY=sk-or-...

# Finished games submit to the public Evalatro leaderboard by default.
# SUBMIT=false # opt out entirely (or pass --no-submit)
# SUBMIT_URL=https://your-leaderboard.example # advanced: override public leaderboard
